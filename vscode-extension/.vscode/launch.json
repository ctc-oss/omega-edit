{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run ╬®editŌäó Hex Editor Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--disable-extensions",
        "--disable-workspace-trust",
        "--skip-welcome",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "npm: compile"
    }
  ]
}
