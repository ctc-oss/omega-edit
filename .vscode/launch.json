{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run OmegaEdit VS Code Example",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--disable-extensions",
        "--disable-workspace-trust",
        "--skip-welcome",
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-extension"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode-extension/out/**/*.js"
      ],
      "windows": {
        "env": {
          "CPP_SERVER_BINARY": "${workspaceFolder}/packages/server/out/bin/omega-edit-grpc-server.exe",
          "CPP_TRANSFORM_PLUGIN_HOST_BINARY": "${workspaceFolder}/packages/server/out/bin/omega-transform-plugin-host.exe"
        }
      },
      "preLaunchTask": "compile:vscode-extension"
    }
  ]
}
