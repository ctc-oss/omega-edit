{
  "name": "@omega-edit/client",
  "version": "2.0.0",
  "description": "OmegaEdit gRPC Client",
  "publisher": "ctc-oss",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "typings": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./change-log/node": {
      "import": {
        "types": "./dist/esm/changeLog/node/index.d.ts",
        "default": "./dist/esm/changeLog/node/index.js"
      },
      "require": {
        "types": "./dist/cjs/changeLog/node/index.d.ts",
        "default": "./dist/cjs/changeLog/node/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "url": "https://github.com/ctc-oss/omega-edit",
    "type": "git"
  },
  "bugs": {
    "url": "https://github.com/ctc-oss/omega-edit/issues"
  },
  "author": "CTC-OSS",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "config": {
    "protocVersion": "35.1"
  },
  "scripts": {
    "pretest": "yarn build && node scripts/ensure-server-prepackaged.js",
    "clean": "rimraf dist",
    "generate-version": "node scripts/generate-version.js",
    "generate:protobuf": "node scripts/generate-protobuf.js",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build": "yarn clean && yarn generate-version && yarn compile-src && yarn build:esm && yarn build:cjs && node ../../scripts/write-dist-package-jsons.js",
    "compile-src": "yarn generate:protobuf",
    "docgen": "typedoc",
    "prepare": "yarn build",
    "package": "yarn prepare && node ../../scripts/pack-workspace.js omega-edit-node-client",
    "test:prepare": "node scripts/ensure-test-prereqs.cjs",
    "test:client": "node scripts/run-vitest-suite.cjs client",
    "test:codec": "vitest run --config vitest.codec.config.ts",
    "test:lifecycle": "node scripts/run-vitest-suite.cjs lifecycle",
    "benchmark:undo": "node scripts/run-undo-benchmark.cjs",
    "benchmark:changelog": "yarn generate-version && node scripts/run-changelog-benchmark.cjs",
    "test:coverage": "yarn build && node scripts/run-vitest-suite.cjs coverage",
    "test:coverage:uds": "yarn build && node scripts/run-vitest-suite.cjs coverage --transport uds",
    "test:client:uds": "node scripts/run-vitest-suite.cjs client --transport uds",
    "test:lifecycle:uds": "node scripts/run-vitest-suite.cjs lifecycle --transport uds",
    "test:uds": "(yarn test:lifecycle:uds && yarn test:client:uds) || (exit 1)",
    "test": "(yarn test:lifecycle && yarn test:client) || (exit 1)",
    "lint": "biome ci .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@protobuf-ts/plugin": "^2.11.1",
    "@protobuf-ts/protoc": "^2.11.1",
    "@vitest/coverage-v8": "^4.1.10",
    "rimraf": "^6.1.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@grpc/grpc-js": "1.14.4",
    "@omega-edit/server": "2.0.0",
    "@protobuf-ts/runtime": "^2.11.1",
    "@protobuf-ts/runtime-rpc": "^2.11.1",
    "pino": "10.3.1",
    "wait-port": "1.1.0"
  }
}
