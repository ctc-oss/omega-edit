{
  "name": "@omega-edit/client",
  "version": "1.0.1",
  "description": "OmegaEdit gRPC Client",
  "publisher": "ctc-oss",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "typings": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "url": "https://github.com/ctc-oss/omega-edit",
    "type": "git"
  },
  "bugs": {
    "url": "https://github.com/ctc-oss/omega-edit/issues"
  },
  "author": "CTC-OSS",
  "license": "Apache-2.0",
  "scripts": {
    "pretest": "yarn build && node scripts/ensure-server-prepackaged.js",
    "clean": "rimraf dist",
    "generate-version": "node scripts/generate-version.js",
    "generate:protobuf": "node scripts/generate-protobuf.js",
    "generate:protobuf-ts": "yarn generate:protobuf",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build": "yarn clean && yarn generate-version && yarn compile-src && yarn build:esm && yarn build:cjs && node ../../scripts/write-dist-package-jsons.js",
    "compile-src": "yarn generate:protobuf",
    "docgen": "typedoc",
    "prepare": "yarn build",
    "package": "yarn prepare && node ../../scripts/pack-workspace.js omega-edit-node-client",
    "test:client": "mocha --timeout 100000 --slow 50000 --require tests/register.js --require tests/fixtures.ts --exclude ./tests/specs/server.spec.ts ./tests/specs/*.spec.ts --exit",
    "test:lifecycle": "mocha --timeout 50000 --slow 35000 --require tests/register.js ./tests/specs/server.spec.ts --exit",
    "test:coverage": "c8 --all --src src --exclude-after-remap --exclude=src/**/*.d.ts --exclude=src/client_version.ts --exclude=src/protobuf_ts/generated/** --exclude=dist/** --exclude=tests/** --exclude=scripts/** --check-coverage --lines 75 --branches 75 --functions 75 --statements 75 --reporter=lcov --reporter=text --reports-dir=coverage node scripts/run-coverage-tests.js",
    "test:client:uds": "OMEGA_EDIT_TEST_TRANSPORT=uds mocha --timeout 100000 --slow 50000 --require tests/register.js --require tests/fixtures.ts --exclude ./tests/specs/server.spec.ts ./tests/specs/*.spec.ts --exit",
    "test:lifecycle:uds": "OMEGA_EDIT_TEST_TRANSPORT=uds mocha --timeout 50000 --slow 35000 --require tests/register.js ./tests/specs/server.spec.ts --exit",
    "test:uds": "(yarn test:lifecycle:uds && yarn test:client:uds) || (exit 1)",
    "test": "(yarn test:lifecycle && yarn test:client) || (exit 1)",
    "lint": "prettier --check package.json webpack.config.js src tests && eslint .",
    "lint:fix": "prettier --write package.json webpack.config.js src tests && eslint --fix ."
  },
  "devDependencies": {
    "@protobuf-ts/plugin": "^2.11.1",
    "@types/chai": "^5.2.3",
    "chai": "^6.2.2",
    "clean-webpack-plugin": "^4.0.0",
    "grpc-tools": "^1.13.1",
    "c8": "^11.0.0",
    "pino-webpack-plugin": "^2.0.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  },
  "dependencies": {
    "@grpc/grpc-js": "1.12.2",
    "@omega-edit/server": "1.0.1",
    "@protobuf-ts/runtime": "^2.11.1",
    "@protobuf-ts/runtime-rpc": "^2.11.1",
    "pid-port": "2.0.1",
    "pino": "10.3.1",
    "wait-port": "1.1.0"
  }
}
