{
  "name": "@omega-edit/ai",
  "version": "2.0.0-rc1",
  "description": "AI-facing CLI and MCP tooling for OmegaEdit",
  "publisher": "ctc-oss",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "typings": "./dist/esm/index.d.ts",
  "bin": {
    "oe": "./dist/cjs/cli.js",
    "omega-edit-mcp": "./dist/cjs/mcp.js"
  },
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "url": "https://github.com/ctc-oss/omega-edit",
    "type": "git"
  },
  "bugs": {
    "url": "https://github.com/ctc-oss/omega-edit/issues"
  },
  "author": "CTC-OSS",
  "license": "Apache-2.0",
  "scripts": {
    "clean": "rimraf dist",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build": "yarn clean && yarn build:esm && yarn build:cjs && node ../../scripts/write-dist-package-jsons.js",
    "prepare": "yarn build",
    "package": "yarn prepare && node ../../scripts/pack-workspace.js omega-edit-node-ai",
    "pretest": "yarn build",
    "test": "mocha --timeout 90000 --require ts-node/register tests/specs/*.spec.ts --exit",
    "lint": "biome ci .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "@omega-edit/client": "2.0.0-rc1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.2",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2"
  }
}
