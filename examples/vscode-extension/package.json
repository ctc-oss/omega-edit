{
  "name": "omega-edit-data-editor",
  "displayName": "%omegaEdit.displayName%",
  "description": "%omegaEdit.description%",
  "version": "2.0.0",
  "publisher": "ctc-oss",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ctc-oss/omega-edit.git"
  },
  "homepage": "https://github.com/ctc-oss/omega-edit/tree/main/examples/vscode-extension",
  "bugs": {
    "url": "https://github.com/ctc-oss/omega-edit/issues"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:omegaEdit.hexEditor",
    "onCommand:omegaEdit.openInHexEditor",
    "onCommand:omegaEdit.goToOffset",
    "onCommand:omegaEdit.searchNext",
    "onCommand:omegaEdit.searchPrevious",
    "onCommand:omegaEdit.undo",
    "onCommand:omegaEdit.redo",
    "onCommand:omegaEdit.refreshTransformPlugins",
    "onCommand:omegaEdit.exportChangeScript",
    "onCommand:omegaEdit.replayChangeScript",
    "onCommand:omegaEdit.rollbackSession",
    "onCommand:omegaEdit.rollbackCheckpoint",
    "onCommand:omegaEdit.createCheckpoint",
    "onCommand:omegaEdit.getEditorState",
    "onCommand:omegaEdit.setExternalHighlights",
    "onCommand:omegaEdit.clearExternalHighlights"
  ],
  "main": "./out/extension.js",
  "types": "./out/api.d.ts",
  "contributes": {
    "customEditors": [
      {
        "viewType": "omegaEdit.hexEditor",
        "displayName": "%omegaEdit.customEditor.displayName%",
        "selector": [
          {
            "filenamePattern": "*"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "%omegaEdit.configuration.title%",
      "properties": {
        "omegaEdit.serverPort": {
          "type": "number",
          "default": 9000,
          "description": "%omegaEdit.configuration.serverPort.description%"
        },
        "omegaEdit.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "trace",
            "debug",
            "info",
            "warn",
            "error",
            "fatal"
          ],
          "description": "%omegaEdit.configuration.logLevel.description%"
        },
        "omegaEdit.bytesPerRow": {
          "type": "number",
          "default": 16,
          "enum": [
            8,
            16,
            32
          ],
          "description": "%omegaEdit.configuration.bytesPerRow.description%"
        },
        "omegaEdit.transformPluginDirectories": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "%omegaEdit.configuration.transformPluginDirectories.description%"
        }
      }
    },
    "commands": [
      {
        "command": "omegaEdit.openInHexEditor",
        "title": "%omegaEdit.command.openInHexEditor.title%"
      },
      {
        "command": "omegaEdit.goToOffset",
        "title": "%omegaEdit.command.goToOffset.title%"
      },
      {
        "command": "omegaEdit.searchNext",
        "title": "%omegaEdit.command.searchNext.title%",
        "enablement": "omegaEdit.hexEditorActive"
      },
      {
        "command": "omegaEdit.searchPrevious",
        "title": "%omegaEdit.command.searchPrevious.title%",
        "enablement": "omegaEdit.hexEditorActive"
      },
      {
        "command": "omegaEdit.undo",
        "title": "%omegaEdit.command.undo.title%",
        "enablement": "omegaEdit.hexEditorActive && omegaEdit.canUndo"
      },
      {
        "command": "omegaEdit.redo",
        "title": "%omegaEdit.command.redo.title%",
        "enablement": "omegaEdit.hexEditorActive && omegaEdit.canRedo"
      },
      {
        "command": "omegaEdit.refreshTransformPlugins",
        "title": "%omegaEdit.command.refreshTransformPlugins.title%",
        "enablement": "omegaEdit.hexEditorActive"
      },
      {
        "command": "omegaEdit.exportChangeScript",
        "title": "%omegaEdit.command.exportChangeScript.title%",
        "enablement": "omegaEdit.hexEditorActive && omegaEdit.hasPendingChanges"
      },
      {
        "command": "omegaEdit.replayChangeScript",
        "title": "%omegaEdit.command.replayChangeScript.title%"
      },
      {
        "command": "omegaEdit.rollbackSession",
        "title": "%omegaEdit.command.rollbackSession.title%",
        "enablement": "omegaEdit.hexEditorActive && omegaEdit.hasPendingChanges"
      },
      {
        "command": "omegaEdit.rollbackCheckpoint",
        "title": "%omegaEdit.command.rollbackCheckpoint.title%",
        "enablement": "omegaEdit.hexEditorActive"
      },
      {
        "command": "omegaEdit.createCheckpoint",
        "title": "%omegaEdit.command.createCheckpoint.title%",
        "enablement": "omegaEdit.hexEditorActive"
      },
      {
        "command": "omegaEdit.getEditorState",
        "title": "%omegaEdit.command.getEditorState.title%"
      },
      {
        "command": "omegaEdit.setExternalHighlights",
        "title": "%omegaEdit.command.setExternalHighlights.title%"
      },
      {
        "command": "omegaEdit.clearExternalHighlights",
        "title": "%omegaEdit.command.clearExternalHighlights.title%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "omegaEdit.openInHexEditor",
          "when": "resourceScheme == file",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "omegaEdit.openInHexEditor",
          "when": "resourceScheme == file",
          "group": "navigation"
        },
        {
          "command": "omegaEdit.rollbackSession",
          "when": "omegaEdit.hexEditorActive && omegaEdit.hasPendingChanges",
          "group": "navigation@9"
        }
      ],
      "commandPalette": [
        {
          "command": "omegaEdit.openInHexEditor"
        },
        {
          "command": "omegaEdit.searchNext",
          "when": "omegaEdit.hexEditorActive"
        },
        {
          "command": "omegaEdit.searchPrevious",
          "when": "omegaEdit.hexEditorActive"
        },
        {
          "command": "omegaEdit.undo",
          "when": "omegaEdit.hexEditorActive"
        },
        {
          "command": "omegaEdit.redo",
          "when": "omegaEdit.hexEditorActive"
        },
        {
          "command": "omegaEdit.refreshTransformPlugins",
          "when": "omegaEdit.hexEditorActive"
        },
        {
          "command": "omegaEdit.rollbackSession",
          "when": "omegaEdit.hexEditorActive && omegaEdit.hasPendingChanges"
        },
        {
          "command": "omegaEdit.rollbackCheckpoint",
          "when": "omegaEdit.hexEditorActive"
        },
        {
          "command": "omegaEdit.createCheckpoint",
          "when": "omegaEdit.hexEditorActive"
        },
        {
          "command": "omegaEdit.getEditorState",
          "when": "false"
        },
        {
          "command": "omegaEdit.setExternalHighlights",
          "when": "false"
        },
        {
          "command": "omegaEdit.clearExternalHighlights",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run compile:extension && npm run check:webview && npm run compile:webview",
    "compile:extension": "tsc -p ./",
    "check:webview": "svelte-check --tsconfig ./webview-ui/tsconfig.json",
    "compile:webview": "vite build",
    "watch": "tsc -watch -p ./",
    "watch:webview": "vite build --watch",
    "package:vsix": "vsce package --out omega-edit-data-editor.vsix",
    "format:check": "biome format .",
    "format:write": "biome format --write .",
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "test:unit": "node --test tests/extension.test.js",
    "test:integration": "node ./tests/run-vscode-tests.js",
    "test:integration:observe": "node ./tests/run-vscode-observe.js",
    "test": "npm run lint && npm run compile && npm run test:unit && npm run test:integration"
  },
  "dependencies": {
    "@omega-edit/client": "file:../../packages/client"
  },
  "overrides": {
    "mocha": {
      "brace-expansion": "2.0.3",
      "serialize-javascript": "7.0.5"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^22.12.0",
    "@types/vscode": "^1.110.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "mocha": "^10.8.2",
    "svelte": "^5.56.3",
    "svelte-check": "^4.1.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.16"
  }
}
