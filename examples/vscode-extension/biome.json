{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "files": {
    "includes": [
      "package.json",
      "tsconfig.json",
      ".vscode/*.json",
      "src/**",
      "tests/**"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5",
      "semicolons": "asNeeded"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "overrides": [
    {
      "includes": ["src/webview.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noUselessEscapeInString": "off"
          }
        }
      }
    },
    {
      "includes": ["tests/**/*.js"],
      "javascript": {
        "globals": ["suite", "suiteSetup", "teardown", "test"]
      }
    }
  ]
}
