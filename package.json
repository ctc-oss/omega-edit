{
  "name": "@omega-edit/core",
  "version": "2.0.0",
  "private": true,
  "description": "OmegaEdit Client and Server",
  "publisher": "CTC-OSS",
  "repository": {
    "url": "https://github.com/ctc-oss/omega-edit",
    "type": "git"
  },
  "bugs": {
    "url": "https://github.com/ctc-oss/omega-edit/issues"
  },
  "author": "CTC-OSS",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check:proto-paths": "node scripts/check-canonical-proto-paths.js",
    "sync-version": "node sync-version.js",
    "dev:help": "node scripts/dev.js help",
    "dev:doctor": "node scripts/dev.js doctor",
    "dev:setup": "node scripts/dev.js deps",
    "native": "node scripts/dev.js native",
    "core:configure": "node scripts/dev.js core:configure",
    "core:build": "node scripts/dev.js core:build",
    "core:test": "node scripts/dev.js core:test",
    "core:install": "node scripts/dev.js core:install",
    "server:configure": "node scripts/dev.js server:configure",
    "server:build": "node scripts/dev.js server:build",
    "packages:build": "node scripts/dev.js packages",
    "packages:test": "node scripts/dev.js packages:test",
    "vscode:setup": "node scripts/dev.js vscode:setup",
    "vscode:build": "node scripts/dev.js vscode:build",
    "vscode:test": "node scripts/dev.js vscode:test",
    "vscode:test:unit": "node scripts/dev.js vscode:test:unit",
    "vscode:test:integration": "node scripts/dev.js vscode:test:integration",
    "vscode:package": "node scripts/dev.js vscode:package",
    "lint": "yarn check:proto-paths && biome ci package.json biome.json sync-version.js scripts packages vscode-extension/package.json vscode-extension/tsconfig.json vscode-extension/src vscode-extension/tests",
    "lint:fix": "yarn check:proto-paths && biome check --write package.json biome.json sync-version.js scripts packages vscode-extension/package.json vscode-extension/tsconfig.json vscode-extension/src vscode-extension/tests",
    "package": "yarn workspace @omega-edit/server package && yarn workspace @omega-edit/client package && yarn workspace @omega-edit/ai package"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^22.20.0",
    "run-script-os": "^1.1.6",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.9"
  },
  "resolutions": {
    "@types/node": "22.20.0",
    "globby/**/brace-expansion": "1.1.13",
    "rimraf/**/brace-expansion": "1.1.13"
  },
  "dependencies": {
    "typescript-language-server": "5.3.0"
  }
}
