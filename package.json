{
  "name": "@omega-edit/core",
  "version": "2.0.0",
  "private": "true",
  "description": "OmegaEdit Client and Server",
  "publisher": "CTC-OSS",
  "repository": {
    "url": "https://github.com/ctc-oss/omega-edit",
    "type": "git"
  },
  "bugs": {
    "url": "https://github.com/ctc-oss/omega-edit/issues"
  },
  "author": "CTC-OSS",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check:proto-paths": "node scripts/check-canonical-proto-paths.js",
    "sync-version": "node sync-version.js",
    "lint": "yarn check:proto-paths && biome ci package.json biome.json sync-version.js scripts packages examples/vscode-extension/package.json examples/vscode-extension/tsconfig.json examples/vscode-extension/src examples/vscode-extension/tests",
    "lint:fix": "yarn check:proto-paths && biome check --write package.json biome.json sync-version.js scripts packages examples/vscode-extension/package.json examples/vscode-extension/tsconfig.json examples/vscode-extension/src examples/vscode-extension/tests",
    "package": "yarn workspace @omega-edit/server package && yarn workspace @omega-edit/client package && yarn workspace @omega-edit/ai package"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/chai": "^5.2.3",
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "chai": "^6.2.2",
    "copy-webpack-plugin": "^14.0.0",
    "mocha": "^10.8.2",
    "run-script-os": "^1.1.6",
    "ts-loader": "^9.5.7",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.2",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  },
  "resolutions": {
    "@types/eslint-scope": "8.4.0",
    "@types/glob": "9.0.0",
    "copy-webpack-plugin/**/ajv": "8.18.0",
    "copy-webpack-plugin/**/picomatch": "4.0.4",
    "copy-webpack-plugin/serialize-javascript": "7.0.5",
    "mocha/**/minimatch": "5.1.8",
    "mocha/**/picomatch": "2.3.2",
    "mocha/**/diff": "5.2.2",
    "mocha/serialize-javascript": "7.0.5",
    "ts-loader/**/picomatch": "2.3.2",
    "webpack/**/ajv": "8.18.0",
    "mocha/**/brace-expansion": "2.0.3",
    "c8/**/brace-expansion": "5.0.5",
    "globby/**/brace-expansion": "1.1.13",
    "rimraf/**/brace-expansion": "1.1.13"
  }
}
